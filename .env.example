# ============================================================
# Study Partner Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================================

# REQUIRED — Get a free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OPTIONAL — For Google search results (2500 free/month)
# Sign up at https://serper.dev
# SERPER_API_KEY=your_serper_api_key_here

# OPTIONAL — Model overrides (defaults shown)
# GROQ_MODEL=llama-3.3-70b-versatile
# OLLAMA_MODEL=qwen3:4b

# OPTIONAL — Set to "true" to use Ollama (local) instead of Groq (cloud)
# USE_OLLAMA=false
